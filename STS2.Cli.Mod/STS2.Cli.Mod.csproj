<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>STS2.Cli.Mod</AssemblyName>
    <RootNamespace>STS2.Cli.Mod</RootNamespace>
    <!-- Allow unsafe code for potential pointer operations -->
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
  </PropertyGroup>

  <!-- Game directory reference -->
  <PropertyGroup>
    <STS2GameDir Condition="'$(STS2GameDir)' == ''">/mnt/c/Program Files (x86)/Steam/steamapps/common/Slay the Spire 2</STS2GameDir>
    <ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>None</ResolveAssemblyWarnOrErrorOnTargetArchitectureMismatch>
  </PropertyGroup>

  <!-- Direct references to game assemblies -->
  <ItemGroup>
    <!-- Main game assembly - direct reference enables strong typing -->
    <Reference Include="sts2">
      <HintPath>$(STS2GameDir)/data_sts2_windows_x86_64/sts2.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- Godot C# API -->
    <Reference Include="GodotSharp">
      <HintPath>$(STS2GameDir)/data_sts2_windows_x86_64/GodotSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>

  </ItemGroup>

  <!-- Mod manifest file -->
  <ItemGroup>
    <Content Include="STS2.Cli.Mod.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Deploy to game directory after build -->
  <Target Name="DeployMod" AfterTargets="Build">
    <Message Text="Deploying mod to $(STS2GameDir)/mods/" Importance="high" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(STS2GameDir)/mods/" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(ProjectDir)STS2.Cli.Mod.json" DestinationFolder="$(STS2GameDir)/mods/" SkipUnchangedFiles="true" />
    <Message Text="Mod deployed successfully!" Importance="high" />
  </Target>

</Project>
